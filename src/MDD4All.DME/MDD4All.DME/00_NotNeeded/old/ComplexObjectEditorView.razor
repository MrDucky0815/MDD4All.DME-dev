@namespace MDD4All.DME.Views.EditorView
@using MDD4All.DME.ViewModels.EditorViewModels
@using MDD4All.DME.Views.Buttons.Icons

<div class="editor-card">
    @* Der Header löst das Auf-/Zuklappen aus *@
    <div class="card-header-grid" @onclick="OnToggleExpanded">
        <div class="card-title">
            @* Titel mit eigener Selektions-Logik (blockiert das Einklappen) *@
            <span class="selectable-label" @onclick="OnSelectNode" @onclick:stopPropagation="true"
                  data-tooltip="Select for editing" data-tooltip-pos="right">
                @DataContext.Title
            </span>

            @* Optionales Badge für Objekte *@
            @if (ShowBadge)
            {
                <span class="badge-object">Object</span>
            }
        </div>

        <div class="header-controls-right">
            @* Bereich für Aktions-Buttons (blockiert das Einklappen) *@
            <div class="card-actions" @onclick:stopPropagation="true">
                @if (DataContext.Item != null)
                {
                    <button class="btn btn-danger btn-icon-sm" @onclick="OnDeleteClick"
                        data-tooltip="Delete object" data-tooltip-pos="left">
                        <IconTrash />
                    </button>
                }
                else
                {
                    <button class="btn btn-primary btn-icon-sm" @onclick="OnCreateClick"
                        data-tooltip="Create instance" data-tooltip-pos="left">
                        <IconCreate />
                    </button>
                }
            </div>

            @if (DataContext.Item != null)
            {
                @* FIX: Der Pfeil liegt außerhalb der card-actions, damit der Klick durchgeht *@
                <div class="expander-icon-right"
                 data-tooltip="@(IsExpanded ? "Collapse" : "Expand")"
                 data-tooltip-pos="left">
                    @(IsExpanded ? "▼" : "▲")
                </div>
            }
        </div>
    </div>

    @* Anzeige des Inhalts nur im ausgeklappten Zustand *@
    @if (IsExpanded && DataContext.Item != null)
    {
        <div class="card-content">
            @if (DataContext.Children != null)
            {
                @foreach (var node in DataContext.Children)
                {
                    <div class="mb-1">
                        @if (node is ComplexObjectEditorViewModel complexVm)
                        {
                            <ComplexObjectEditorView DataContext="complexVm" />
                        }
                        else if (node is IndexedCollectionEditorViewModel collectionVM)
                        {
                            <IndexedCollectionEditorView DataContext="collectionVM" />
                        }
                        else if (node is PrimitivePropertyViewModel primitiveVm)
                        {
                            @* Standard-Primitive-Ansicht innerhalb eines Objekts *@
                            <PrimitivePropertyEditorView ViewModel="primitiveVm" IsCompact="false" />
                        }
                        else if (node is DictionaryEditorViewModel subDictVm)
                        {
                            <DictionaryEditorView DataContext="subDictVm" />
                        }
                    </div>
                }
            }
        </div>
    }
</div>