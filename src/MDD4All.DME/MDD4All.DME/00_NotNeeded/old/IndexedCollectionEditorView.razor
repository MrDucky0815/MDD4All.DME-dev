@namespace MDD4All.DME.Views.EditorView
@using MDD4All.DME.ViewModels.EditorViewModels
@using MDD4All.DME.Views.Buttons.Icons

<div class="editor-card @(DeleteMode ? "delete-mode-active" : "")">
    @* --- MANUELLER HEADER --- *@
    <div class="card-header-grid" @onclick="OnToggleExpanded">
        <div class="card-title">
            <span class="selectable-label" @onclick="OnSelectNode" @onclick:stopPropagation="true"
                  data-tooltip="Für Bearbeitung auswählen">
                @DataContext.Title
            </span>
            <span class="badge-list">@DataContext.BadgeText</span>
        </div>

        <div class="header-controls-right">
            <div class="card-actions" @onclick:stopPropagation="true">
                @if (DataContext.Item != null)
                {
                    @* Button: Element hinzufügen *@
                    <button class="btn btn-success btn-icon-sm" @onclick="OnAddClick" data-tooltip="Hinzufügen">
                        <IconAdd /> @* *@
                    </button>

                    @* Button: Löschmodus (nur bei einfachen Typen) *@
                    @if (DataContext.IsUnderlyingTypeSimple)
                    {
                        <button class="btn @(DeleteMode ? "btn-toggle-on" : "btn-toggle-off") btn-icon-sm"
                        @onclick="OnToggleDeleteMode" data-tooltip="Löschmodus">
                            <IconDeleteMode IsActive="@DeleteMode" /> @* *@
                        </button>
                    }

                    @* Button: Die gesamte Liste löschen *@
                    <button class="btn btn-danger btn-icon-sm" @onclick="OnDeleteItemClick" data-tooltip="Liste löschen">
                        <IconTrash /> @* *@
                    </button>
                }
                else
                {
                    @* Button: Instanz erstellen *@
                    <button class="btn btn-primary btn-icon-sm" @onclick="OnCreateClick" data-tooltip="Instanz erstellen">
                        <IconCreate /> @* *@
                    </button>
                }
            </div>

            @if (DataContext.Item != null)
            {
                <div class="expander-icon-right">
                    @(IsExpanded ? "▼" : "▲")
                </div>
            }
        </div>
    </div>

    @* --- INHALT --- *@
    @if (IsExpanded && DataContext.Item != null)
    {
        <div class="card-content">
            <div class="@(DataContext.IsUnderlyingTypeSimple ? "grid-flow" : "")">
                @foreach (var child in DataContext.Children)
                {
                    @if (child is PrimitivePropertyViewModel primitiveVm)
                    {
                        <div class="primitive-tile">
                            @if (DeleteMode)
                            {
                                <button class="btn-tile-delete" @onclick="() => OnSimpleDeleteChildClick(primitiveVm)" data-tooltip="Entfernen">
                                    <IconTrash />
                                </button>
                            }
                            <PrimitivePropertyEditorView ViewModel="primitiveVm" IsCompact="true" />
                        </div>
                    }
                    else
                    {
                        <div class="mb-1">
                            @if (child is ComplexObjectEditorViewModel complexVm)
                            {
                                <ComplexObjectEditorView DataContext="complexVm" />
                            }
                            else if (child is IndexedCollectionEditorViewModel subCollectionVm)
                            {
                                <IndexedCollectionEditorView DataContext="subCollectionVm" />
                            }
                            else if (child is DictionaryEditorViewModel subDictVm)
                            {
                                <DictionaryEditorView DataContext="subDictVm" />
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>